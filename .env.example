# TravixPay Environment Variables
# Copy this file to .env and fill in your values

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Site URL (used for callbackUrl in Nomba checkout)
# Sandbox: http://127.0.0.1:8000
# Production: https://yourdomain.com
SITE_URL=http://127.0.0.1:8000

# Nomba Environment
# sandbox: No credentials needed. Calls sandbox.nomba.com directly.
# production: Requires all NOMBA_* credentials below.
NOMBA_ENV=sandbox

# Payment Confirmation Mode
# VERIFY_ONLY: Callback verifies payment via Nomba API, credits wallet immediately.
# WEBHOOK_REQUIRED: Webhook is source of truth, callback only shows status.
PAYMENT_CONFIRMATION_MODE=VERIFY_ONLY

# --- Nomba Credentials (PRODUCTION ONLY) ---
# These are NOT required in sandbox mode.
# NOMBA_CLIENT_ID=your-client-id
# NOMBA_CLIENT_SECRET=your-client-secret
# NOMBA_PARENT_ACCOUNT_ID=your-parent-account-id
# NOMBA_WEBHOOK_SECRET=your-webhook-secret
